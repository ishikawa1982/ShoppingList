rules_version = '2';

// 匿名認証（Firebase Anonymous Auth）導入後のルール。
// Firebase SDK 経由でサインイン（匿名含む）したユーザーのみ読み書き可。
// ボードID は推測されにくい乱数で、「リンクを知っている認証済みユーザーのみ」
// がアクセスできる共有モデルです（家族で使う MVP 向け）。
service cloud.firestore {
  match /databases/{database}/documents {
    match /boards/{boardId} {
      allow read, write: if request.auth != null;
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
