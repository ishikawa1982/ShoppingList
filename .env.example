# Firebase 設定（任意）。共有機能を使う場合に設定します。
# このファイルを .env.local にコピーして値を埋めてください。
# ※ これらの値は公開されても問題ありません（セキュリティは Firestore ルールで担保）。
# ※ src/lib/firebaseConfig.js に直接書く方法でも構いません（そちらが簡単）。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
